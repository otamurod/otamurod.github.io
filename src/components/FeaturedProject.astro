---
import Container from "./Container.astro";
import SectionLabel from "./SectionLabel.astro";
import PhoneRing from "./PhoneRing.astro";
import { FEATURED_PROJECT as P } from "../consts";
---

<section
  id="projects"
  class="relative scroll-mt-24 pt-8 pb-12 md:pt-10 md:pb-14"
  aria-labelledby="featured-label"
>
  <Container>
    <div class="max-w-5xl">
      <SectionLabel label="Featured Project" index="03" class="reveal" />
      <h2 id="featured-label" class="sr-only">Featured Project</h2>

      <article
        class="reveal relative mt-10 overflow-hidden rounded-3xl border border-border/60 bg-gradient-to-br from-surface/90 via-surface to-card/70 p-6 shadow-xl shadow-primary/[0.04] sm:p-8 md:mt-12 md:p-10 lg:p-12"
        style="--reveal-delay: 80ms"
      >
        <div
          class="pointer-events-none absolute -top-40 -right-32 h-96 w-96 rounded-full bg-primary/25 blur-3xl"
          aria-hidden="true"
        >
        </div>
        <div
          class="pointer-events-none absolute -bottom-40 -left-40 h-80 w-80 rounded-full bg-primary/10 blur-3xl"
          aria-hidden="true"
        >
        </div>

        <div class="relative">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div
              class="inline-flex items-center gap-2 rounded-full border border-border/60 bg-bg/60 px-3 py-1 text-xs font-medium text-muted backdrop-blur-sm"
            >
              <span class="relative flex h-1.5 w-1.5" aria-hidden="true">
                <span
                  class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary/60"
                ></span>
                <span
                  class="relative inline-flex h-1.5 w-1.5 rounded-full bg-primary"
                ></span>
              </span>
              {P.category}
            </div>

            <a
              href={P.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group/cta inline-flex items-center gap-2 rounded-full bg-primary px-4 py-2 text-sm font-semibold text-white shadow-lg shadow-primary/25 transition hover:bg-primary-hover hover:shadow-primary/40"
            >
              <svg
                viewBox="0 0 24 24"
                class="h-4 w-4"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M22.018 13.298l-3.919 2.218-3.515-3.493 3.543-3.521 3.891 2.202a1.49 1.49 0 0 1 0 2.594zM1.337.924a1.486 1.486 0 0 0-.112.568v21.017c0 .217.045.419.124.6l11.155-11.087L1.337.924zm12.207 10.065l3.258-3.238L3.45.195a1.466 1.466 0 0 0-.946-.179l11.04 10.973zm0 2.067l-11 10.933c.298.036.612-.016.906-.183l13.324-7.54-3.23-3.21z"/>
              </svg>
              Get on Google Play
              <svg
                viewBox="0 0 24 24"
                class="h-4 w-4 transition-transform group-hover/cta:translate-x-1"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M5 12h14" />
                <path d="M13 6l6 6-6 6" />
              </svg>
            </a>
          </div>

          <h3
            class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl md:text-5xl"
          >
            {P.name}<span class="text-primary">.</span>
          </h3>

          <p class="mt-2 text-sm font-medium text-muted sm:text-base">
            {P.tagline}
          </p>

          <p
            class="mt-5 max-w-3xl text-base leading-relaxed text-muted sm:text-lg"
          >
            {P.description}
          </p>

          <div class="mt-6 border-t border-border/50 pt-4">
            <PhoneRing />
          </div>

          <div class="mt-6 flex flex-wrap items-center gap-2.5">
            <div
              class="inline-flex items-center gap-2 rounded-full border border-border/60 bg-bg/60 px-3 py-1.5 backdrop-blur-sm"
            >
              <div class="flex items-center gap-0.5" aria-hidden="true">
                {
                  Array.from({ length: 5 }).map((_, i) => (
                    <svg
                      viewBox="0 0 24 24"
                      class={`h-3.5 w-3.5 ${i < Math.round(P.stats.rating) ? "text-amber-400" : "text-border"}`}
                      fill="currentColor"
                    >
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                    </svg>
                  ))
                }
              </div>
              <span class="text-sm leading-none">
                <span class="font-semibold text-text tabular-nums">
                  {P.stats.rating}
                </span>
                <span class="text-muted">
                  {" "}
                  · {P.stats.ratingCount} reviews
                </span>
              </span>
            </div>

            <div
              class="inline-flex items-center gap-2 rounded-full border border-border/60 bg-bg/60 px-3 py-1.5 backdrop-blur-sm"
            >
              <svg
                viewBox="0 0 24 24"
                class="h-4 w-4 text-primary"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M12 3v13" />
                <path d="M6 10l6 6 6-6" />
                <path d="M4 21h16" />
              </svg>
              <span class="text-sm leading-none">
                <span class="font-semibold text-text tabular-nums">
                  {P.stats.downloads}
                </span>
                <span class="text-muted"> downloads</span>
              </span>
            </div>
          </div>

          <ul
            class="mt-5 flex flex-wrap items-center gap-x-5 gap-y-2 text-xs text-muted"
            aria-label="Project status"
          >
            {
              P.status.map((s, i) => (
                <li class="inline-flex items-center gap-1.5">
                  {s.tone === "live" && (
                    <span class="relative flex h-2 w-2" aria-hidden="true">
                      <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-70" />
                      <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400" />
                    </span>
                  )}
                  {s.tone === "primary" && (
                    <svg
                      viewBox="0 0 24 24"
                      class="status-icon status-icon--spin h-3.5 w-3.5 text-primary"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <circle cx="12" cy="12" r="8" opacity=".25" />
                      <path d="M12 2v4" />
                      <path d="M12 18v4" />
                      <path d="M4.93 4.93l2.83 2.83" />
                      <path d="M16.24 16.24l2.83 2.83" />
                      <path d="M2 12h4" />
                      <path d="M18 12h4" />
                      <path d="M4.93 19.07l2.83-2.83" />
                      <path d="M16.24 7.76l2.83-2.83" />
                    </svg>
                  )}
                  {s.tone === "muted" && (
                    <svg
                      viewBox="0 0 24 24"
                      class="status-icon status-icon--float h-3.5 w-3.5 text-muted"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M17.05 12.53a4.34 4.34 0 0 1 2.07-3.65 4.44 4.44 0 0 0-3.5-1.9c-1.47-.16-2.9.87-3.64.87-.76 0-1.92-.85-3.16-.83A4.66 4.66 0 0 0 4.9 9.4c-1.68 2.92-.43 7.24 1.21 9.6.8 1.15 1.76 2.45 3.02 2.4 1.21-.05 1.67-.78 3.14-.78 1.46 0 1.88.78 3.16.75 1.3-.02 2.13-1.17 2.93-2.33a10.3 10.3 0 0 0 1.34-2.72 4.2 4.2 0 0 1-2.65-3.79zM14.7 5.28A4.19 4.19 0 0 0 15.7 2a4.28 4.28 0 0 0-2.75 1.42 3.98 3.98 0 0 0-1.03 3.16 3.55 3.55 0 0 0 2.79-1.3z" />
                    </svg>
                  )}
                  <span>{s.label}</span>
                  {i < P.status.length - 1 && (
                    <span class="ml-3 text-border" aria-hidden="true">
                      |
                    </span>
                  )}
                </li>
              ))
            }
          </ul>

          <ul class="mt-8 grid grid-cols-1 gap-x-6 gap-y-2.5 sm:grid-cols-2">
            {
              P.features.map((f) => (
                <li class="flex items-start gap-2.5 text-sm text-muted">
                  <svg
                    viewBox="0 0 24 24"
                    class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M20 6L9 17l-5-5" />
                  </svg>
                  <span>{f}</span>
                </li>
              ))
            }
          </ul>

          <div class="mt-8 flex flex-wrap gap-1.5">
            {
              P.stack.map((tech) => (
                <span class="rounded-full border border-border/60 bg-bg/60 px-2.5 py-1 text-[11px] font-medium text-muted transition-colors hover:border-primary/40 hover:text-text">
                  {tech}
                </span>
              ))
            }
          </div>
        </div>
      </article>
    </div>
  </Container>
</section>

<style>
.status-icon {
  transform-origin: center;
}

.status-icon--spin {
  animation: status-spin 3s linear infinite;
}

.status-icon--float {
  animation: status-float 2.6s ease-in-out infinite;
}

@keyframes status-spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

@keyframes status-float {
  0%,
  100% {
    transform: translateY(0);
    opacity: .75;
  }
  50% {
    transform: translateY(-2px);
    opacity: 1;
  }
}

@media (prefers-reduced-motion: reduce) {
  .status-icon--spin,
  .status-icon--float {
    animation: none;
  }
}
</style>