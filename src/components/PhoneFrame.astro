---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  alt: string;
  index: number;
  eager?: boolean;
}

const { image, alt, index, eager = false } = Astro.props;
---

<div class="phone" data-phone data-index={index}>
  <div class="phone__frame">
    <span class="phone__button phone__button--mute" aria-hidden="true"></span>
    <span class="phone__button phone__button--volup" aria-hidden="true"></span>
    <span class="phone__button phone__button--voldown" aria-hidden="true"></span>
    <span class="phone__button phone__button--power" aria-hidden="true"></span>

    <div class="phone__screen">
      <div class="phone__island" aria-hidden="true"></div>

      <div class="phone__content">
        <Image
          src={image}
          alt={alt}
          class="phone__image"
          widths={[280, 560]}
          sizes="280px"
          loading={eager ? "eager" : "lazy"}
          draggable={false}
        />
      </div>
    </div>
  </div>
</div>

<style>
  .phone {
    position: absolute;
    width: 220px;
    cursor: pointer;
    user-select: none;
    transition:
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.4s,
      opacity 0.4s;
  }

  .phone__frame {
    position: relative;
    padding: 7px;
    border-radius: 36px;

    background: linear-gradient(
      180deg,
      #181b22 0%,
      #0b0d12 45%,
      #050608 100%
    );

    border: 1px solid rgba(255,255,255,.08);

    box-shadow:
      inset 0 1px 1px rgba(255,255,255,.08),
      inset 0 -1px 2px rgba(0,0,0,.55),
      0 24px 70px rgba(0,0,0,.35),
      0 8px 20px rgba(0,0,0,.22);
  }

  .phone__frame::before{
      content:"";
      position:absolute;
      inset:0;
      border-radius:inherit;
      padding:1px;

      background:
          linear-gradient(
              135deg,
              rgba(255,255,255,.22),
              rgba(255,255,255,.04) 25%,
              rgba(0,0,0,.20) 70%,
              rgba(255,255,255,.10)
          );

      -webkit-mask:
          linear-gradient(#fff 0 0) content-box,
          linear-gradient(#fff 0 0);
      -webkit-mask-composite:xor;
      mask-composite:exclude;

      pointer-events:none;
  }

  .phone__screen::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;

      background:
          linear-gradient(
              115deg,
              rgba(255,255,255,.10),
              transparent 35%
          );

      opacity:.6;
  }

  .phone__screen {
    position: relative;
    overflow: hidden;
    border-radius: 29px;
    aspect-ratio: 9 / 19.5;
    background: #0EB161;
  }

  .phone__content {
    height: 100%;
    padding-top: 38px;
  }

  .phone__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .phone__island {
    position: absolute;
    top: 7px;
    left: 50%;
    transform: translateX(-50%);
    width: 96px;
    height: 24px;
    border-radius: 999px;
    background: #000;
    z-index: 5;
  }

  .phone__button {
    position: absolute;
    width: 3px;
    background: #3a3d47;
    border-radius: 999px;
  }
  .phone__button--mute    { left: -2px; top: 74px;  height: 18px; }
  .phone__button--volup   { left: -2px; top: 102px; height: 34px; }
  .phone__button--voldown { left: -2px; top: 142px; height: 34px; }
  .phone__button--power   { right: -2px; top: 112px; height: 54px; }

  .phone.is-active .phone__frame{
    box-shadow:
      inset 0 1px 1px rgba(255,255,255,.10),
      inset 0 -1px 2px rgba(0,0,0,.55),
      0 0 0 1px rgba(124,58,237,.22),
      0 20px 50px rgba(124,58,237,.18),
      0 40px 90px rgba(0,0,0,.35);
  }
</style>
