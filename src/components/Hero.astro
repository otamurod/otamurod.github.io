---
import Container from "./Container.astro";
import { SITE, SOCIAL } from "../consts";
import { Image } from "astro:assets";
import portrait from "../assets/my_photo.webp";

const iconLinks = [
  { href: SOCIAL.github, label: "GitHub", icon: "github" },
  { href: SOCIAL.linkedin, label: "LinkedIn", icon: "linkedin" },
  { href: SOCIAL.googlePlay, label: "Google Play", icon: "play" },
];
---

<section
  id="top"
  class="relative isolate overflow-hidden pt-32 pb-14 md:pt-40 md:pb-20"
>
  <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>

  <div
    class="hero-aurora absolute left-1/2 top-0 -z-10 h-[520px] w-[900px] -translate-x-1/2 rounded-full blur-3xl"
    style="background: radial-gradient(closest-side, rgba(124,58,237,0.45), transparent 70%);"
    aria-hidden="true"
  >
  </div>

  <Container class="grid gap-16 md:grid-cols-[1.15fr_.85fr] md:items-center">
    <div class="hero-cascade max-w-2xl">
      <div
        style="--i: 0"
        class="inline-flex items-center gap-2 rounded-full border border-border/60 bg-surface/60 px-3 py-1 text-xs font-medium text-muted backdrop-blur-sm"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"
          ></span>
          <span
            class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400"
          ></span>
        </span>
        Open to Senior Android &amp; KMP roles
      </div>

      <h1
        style="--i: 1"
        class="mt-6 text-4xl font-semibold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl"
      >
        <span class="block text-muted text-lg font-medium sm:text-xl">
          Hi, I'm
        </span>
        <span class="mt-1 block">
          {SITE.name}<span class="text-primary">.</span>
        </span>
      </h1>

      <p style="--i: 2" class="mt-4 text-lg font-medium text-text sm:text-xl md:text-2xl">
        {SITE.role}
        <span class="text-muted"> · </span>
        <span class="text-muted">{SITE.secondaryRole}</span>
      </p>

      <p style="--i: 3" class="mt-6 max-w-xl text-base leading-relaxed text-muted sm:text-lg">
        {SITE.shortBio}
      </p>

      <div style="--i: 4" class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href={SOCIAL.resume}
          class="group inline-flex items-center gap-2 rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-primary/25 transition hover:bg-primary-hover hover:shadow-primary/40"
        >
          Download Resume
          <svg
            viewBox="0 0 24 24"
            class="h-4 w-4 transition-transform group-hover:translate-y-0.5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M12 4v12" />
            <path d="M6 10l6 6 6-6" />
            <path d="M4 20h16" />
          </svg>
        </a>

        <div
          class="flex items-center gap-1 rounded-full border border-border/60 bg-surface/60 p-1 backdrop-blur-sm"
        >
          {
            iconLinks.map(({ href, label, icon }) => (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={label}
                title={label}
                class="grid h-9 w-9 place-items-center rounded-full text-muted transition-colors hover:bg-card hover:text-text"
              >
                {icon === "github" && (
                  <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
                    <path d="M12 .5C5.65.5.5 5.65.5 12A11.5 11.5 0 0 0 8.37 22.9c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.4-3.88-1.4-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.15.08 1.76 1.19 1.76 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.68 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.17 1.18a11 11 0 0 1 5.77 0c2.2-1.49 3.17-1.18 3.17-1.18.62 1.59.23 2.76.11 3.05.73.81 1.18 1.84 1.18 3.1 0 4.41-2.7 5.38-5.26 5.66.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z" />
                  </svg>
                )}
                {icon === "linkedin" && (
                  <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
                    <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.44-2.13 2.94v5.67H9.36V9h3.42v1.56h.05a3.76 3.76 0 0 1 3.38-1.86c3.61 0 4.28 2.38 4.28 5.47v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.11 2.06 2.06 0 0 1 0 4.11zM7.12 20.45H3.56V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0z" />
                  </svg>
                )}
                {icon === "play" && (
                  <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
                    <path d="M22.018 13.298l-3.919 2.218-3.515-3.493 3.543-3.521 3.891 2.202a1.49 1.49 0 0 1 0 2.594zM1.337.924a1.486 1.486 0 0 0-.112.568v21.017c0 .217.045.419.124.6l11.155-11.087L1.337.924zm12.207 10.065l3.258-3.238L3.45.195a1.466 1.466 0 0 0-.946-.179l11.04 10.973zm0 2.067l-11 10.933c.298.036.612-.016.906-.183l13.324-7.54-3.23-3.21z"/>
                  </svg>
                )}
              </a>
            ))
          }
        </div>
      </div>

      <div style="--i: 5" class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-muted">
        <div class="flex items-center gap-2">
          <svg
            viewBox="0 0 24 24"
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 1 1 16 0z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          <span>{SITE.location}</span>
          <span class="text-border" aria-hidden="true">·</span>
          <span
            id="local-time"
            class="tabular-nums opacity-0 transition-opacity duration-500"
            aria-label={`Local time in ${SITE.location}`}
          ></span>
        </div>
        <div class="flex items-center gap-2">
          <svg
            viewBox="0 0 24 24"
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="9" />
            <path d="M12 7v5l3 2" />
          </svg>
          {SITE.yearsOfExperience} years of experience
        </div>
      </div>
    </div>

    <div class="hero-portrait relative order-first md:order-last mx-auto md:mx-0">
      <div
        class="portrait-glow pointer-events-none absolute -inset-6 -z-10 rounded-full blur-2xl"
        style="background: radial-gradient(closest-side, rgba(124,58,237,0.35), transparent 70%);"
        aria-hidden="true"
      >
      </div>
      <div
        class="portrait group relative aspect-square w-56 overflow-hidden rounded-full border border-border/60 bg-card sm:w-64 md:w-72 lg:w-80 glow-primary transition-all duration-500 hover:border-primary/50"
      >
        <Image
          src={portrait}
          alt={`Portrait of ${SITE.name}`}
          width={640}
          height={640}
          loading="eager"
          class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
      </div>
    </div>
  </Container>

  <a
    href="#about"
    aria-label="Scroll to About section"
    class="scroll-cue group absolute bottom-6 left-1/2 hidden -translate-x-1/2 flex-col items-center gap-2 text-muted transition-opacity duration-500 md:flex"
  >
    <span class="text-[10px] font-medium uppercase tracking-[0.2em]">
      Scroll
    </span>
    <span
      class="relative flex h-8 w-5 items-start justify-center rounded-full border border-border/70 pt-1.5 transition-colors group-hover:border-primary/60"
    >
      <span class="scroll-cue-dot h-1.5 w-1.5 rounded-full bg-muted transition-colors group-hover:bg-primary"></span>
    </span>
  </a>
</section>

<style>
  @keyframes hero-breathe {
    0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.55; }
    50%      { transform: translateX(-50%) scale(1.08); opacity: 0.85; }
  }
  @keyframes portrait-breathe {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50%      { opacity: 1;   transform: scale(1.06); }
  }
  @keyframes scroll-dot {
    0%   { transform: translateY(0);   opacity: 0.9; }
    60%  { transform: translateY(8px); opacity: 0;   }
    61%  { transform: translateY(0);   opacity: 0;   }
    100% { transform: translateY(0);   opacity: 0.9; }
  }

  .hero-aurora {
    animation: hero-breathe 9s ease-in-out infinite;
    will-change: transform, opacity;
  }
  .portrait-glow {
    animation: portrait-breathe 7s ease-in-out infinite;
    will-change: transform, opacity;
  }
  .scroll-cue-dot {
    animation: scroll-dot 2.4s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-aurora, .portrait-glow, .scroll-cue-dot { animation: none; }
  }
</style>

<script>
  // Live Tashkent time — updates every minute, fades in on first render.
  const el = document.getElementById("local-time");
  if (el) {
    const fmt = new Intl.DateTimeFormat("en-US", {
      hour: "numeric",
      minute: "2-digit",
      hour12: true,
      timeZone: "Asia/Tashkent",
    });
    const render = () => {
      el.textContent = `${fmt.format(new Date())} local`;
      el.style.opacity = "1";
    };
    render();
    const nextMinute = 60_000 - (Date.now() % 60_000);
    setTimeout(() => {
      render();
      setInterval(render, 60_000);
    }, nextMinute);
  }

  // Fade the scroll cue as the user leaves the hero.
  const cue = document.querySelector<HTMLElement>(".scroll-cue");
  if (cue) {
    const onScroll = () => {
      const y = window.scrollY;
      cue.style.opacity = String(Math.max(0, 1 - y / 240));
      cue.style.pointerEvents = y > 200 ? "none" : "auto";
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>
